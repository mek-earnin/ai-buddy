# Copy this file to `.env.local` and fill in your values.
# `.env.local` is git-ignored; never commit it.
#
# Loaded automatically by `npm run tauri:build`.

# macOS code-signing identity used to sign the release bundle.
# Find yours with: security find-identity -p codesigning -v
# Using an Apple Development identity (with a Team ID) avoids repeated
# Keychain password prompts on every reinstall. See README → "Code Signing".
APPLE_SIGNING_IDENTITY="Apple Development: you@example.com (XXXXXXXXXX)"

# --- Optional: notarization for distributing to other Macs (paid Apple Developer Program) ---
# APPLE_ID="you@example.com"
# APPLE_PASSWORD="app-specific-password"
# APPLE_TEAM_ID="XXXXXXXXXX"
